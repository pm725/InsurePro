<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'InsurePro' %></title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- CUSTOM CSS -->
    <link rel="stylesheet" href="/css/style.css">
    
    <!-- FALLBACK STYLES -->
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f8f9fa; color: #333; }
        .navbar { background: white !important; border-bottom: 3px solid #dc3545; padding: 10px 0; }
        .navbar-brand { font-weight: 700; font-size: 1.4rem; color: #dc3545 !important; }
        .navbar .nav-link { color: #495057 !important; font-weight: 500; padding: 10px 16px !important; }
        .navbar .nav-link:hover { color: #dc3545 !important; }
        .navbar .nav-link i { margin-right: 6px; }
        .btn-danger { background: #dc3545; border-color: #dc3545; color: white; }
        .btn-danger:hover { background: #a71d2a; border-color: #a71d2a; color: white; }
        .btn-outline-danger { background: transparent; border: 2px solid #dc3545; color: #dc3545; }
        .btn-outline-danger:hover { background: #dc3545; color: white; }
        .text-danger { color: #dc3545 !important; }
        .avatar-circle { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem; background: #dc3545; color: white; }
        .dropdown-menu { border-radius: 12px; padding: 8px 0; border: 1px solid #f0f0f0; box-shadow: 0 4px 20px rgba(0,0,0,0.06); }
        .dropdown-item { padding: 8px 20px; font-size: 0.95rem; color: #495057; }
        .dropdown-item:hover { background: #fdf2f3; color: #dc3545; }
        .dropdown-item i { width: 20px; margin-right: 8px; }
        .dropdown-divider { border-top: 1px solid #e9ecef; margin: 6px 0; }
        .navbar-toggler { border: none; color: #dc3545 !important; }
        .navbar-toggler:focus { box-shadow: 0 0 0 0.2rem rgba(220,53,69,0.15); }
        .shadow-sm { box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
        .sticky-top { position: sticky; top: 0; z-index: 1050; }
    </style>
</head>
<body>

<!-- ===== MAIN NAVBAR - NO TOP BAR ===== -->
<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
    <div class="container">
        <a class="navbar-brand" href="/">
            <i class="fas fa-shield-alt text-danger"></i>
            <span class="fw-bold text-danger">Insure</span><span class="fw-bold text-dark">Pro</span>
            <small class="d-none d-sm-inline text-muted fw-light" style="font-size: 0.7rem; letter-spacing: 1px;">| HEALTH INSURANCE</small>
        </a>
        
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-lg-center">
                
                <% if (user) { %>
                    <!-- ===== LOGGED IN ===== -->
                    
                    <!-- Dashboard -->
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">
                            <i class="fas fa-chart-line text-danger"></i> Dashboard
                        </a>
                    </li>
                    
                    <!-- Services Dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="fas fa-cogs text-danger"></i> Services
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/risk/calculate"><i class="fas fa-calculator text-danger"></i> Calculate Risk</a></li>
                            <li><a class="dropdown-item" href="/claim/file"><i class="fas fa-file-medical text-danger"></i> File Claim</a></li>
                            <li><a class="dropdown-item" href="/claims"><i class="fas fa-list text-danger"></i> My Claims</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/quiz/start"><i class="fas fa-brain text-danger"></i> Health Quiz</a></li>
                        </ul>
                    </li>
                    
                    <!-- Community -->
                    <li class="nav-item">
                        <a class="nav-link" href="/community/tips">
                            <i class="fas fa-users text-danger"></i> Community
                        </a>
                    </li>
                    
                    <!-- Learn -->
                    <li class="nav-item">
                        <a class="nav-link" href="/info">
                            <i class="fas fa-graduation-cap text-danger"></i> Learn
                        </a>
                    </li>
                    
                    <!-- ✅ ADMIN LINK - ONLY FOR ADMINS -->
                    <% if (user.email.includes('admin') || user.id === 1) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/admin/dashboard">
                                <i class="fas fa-crown text-warning"></i> Admin
                            </a>
                        </li>
                    <% } %>
                    
                    <!-- User Dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" data-bs-toggle="dropdown">
                            <div class="avatar-circle bg-danger text-white me-1">
                                <%= user.username.charAt(0).toUpperCase() %>
                            </div>
                            <span class="d-none d-lg-inline"><%= user.username %></span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><span class="dropdown-item-text fw-bold"><%= user.email %></span></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/dashboard"><i class="fas fa-user text-danger"></i> Profile</a></li>
                            <li><a class="dropdown-item" href="/risk/calculate"><i class="fas fa-heartbeat text-danger"></i> Health Status</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger fw-bold" href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                        </ul>
                    </li>
                    
                <% } else { %>
                    <!-- ===== LOGGED OUT ===== -->
                    
                    <li class="nav-item">
                        <a class="nav-link" href="/info">
                            <i class="fas fa-graduation-cap text-danger"></i> Learn
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/community/tips">
                            <i class="fas fa-users text-danger"></i> Community
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-outline-danger btn-sm me-2" href="/login">
                            <i class="fas fa-sign-in-alt"></i> Login
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-danger btn-sm" href="/register">
                            <i class="fas fa-user-plus"></i> Get Started
                        </a>
                    </li>
                    
                <% } %>
                
            </ul>
        </div>
    </div>
</nav>

<!-- ===== MAIN CONTENT STARTS ===== -->
<main class="py-4">