<%- include('../partials/header', { title: 'Quiz Result' }) %>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card text-center">
            <div class="card-body">
                <h3><i class="fas fa-check-circle text-success"></i> Quiz Complete!</h3>
                <h2 class="display-4 my-4"><%= score %>%</h2>
                <p><strong>Health Score</strong></p>
                <p class="text-muted">
                    <% if (score >= 80) { %> Excellent! You're very health-conscious! 🌟
                    <% } else if (score >= 60) { %> Good! Keep improving your habits. 💪
                    <% } else if (score >= 40) { %> Average. Some areas need attention. 🧐
                    <% } else { %> You could make healthier choices. Let's work on it! ❤️
                    <% } %>
                </p>
                <p>Your risk profile has been updated based on your answers.</p>
                <a href="/dashboard" class="btn btn-primary">View Dashboard</a>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>