<%- include('../partials/header', { title: 'Community Tips' }) %>

<h2><i class="fas fa-users"></i> Health Tips Community</h2>
<p class="text-muted">Share and discover health tips</p>

<a href="/community/tip/new" class="btn btn-primary mb-4"><i class="fas fa-plus"></i> Share a Tip</a>

<div class="row">
    <% if (tips && tips.length > 0) { %>
        <% tips.forEach(tip => { %>
            <div class="col-md-6">
                <div class="card mb-3">
                    <div class="card-body">
                        <h5><a href="/community/tip/<%= tip.id %>"><%= tip.title %></a></h5>
                        <p><%= tip.content.substring(0, 100) %>...</p>
                        <small>
                            Posted by <strong><%= tip.User ? tip.User.username : 'Unknown' %></strong>
                            · ❤️ <%= tip.upvotes %> upvotes
                            · <%= new Date(tip.created_at).toLocaleDateString() %>
                        </small>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <p class="text-muted">No tips yet. Be the first to share!</p>
    <% } %>
</div>

<%- include('../partials/footer') %>