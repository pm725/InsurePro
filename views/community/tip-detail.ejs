<%- include('../partials/header', { title: tip.title }) %>

<div class="card mb-4">
    <div class="card-body">
        <h3><%= tip.title %></h3>
        <p><%= tip.content %></p>
        <small>
            Posted by <strong><%= tip.User ? tip.User.username : 'Unknown' %></strong>
            · <%= new Date(tip.created_at).toLocaleDateString() %>
        </small>
        <div class="mt-3">
            <form action="/community/tip/<%= tip.id %>/upvote" method="POST" style="display:inline;">
                <button class="btn <%= userUpvoted ? 'btn-danger' : 'btn-outline-danger' %> btn-sm">
                    ❤️ <%= tip.upvotes %> <%= userUpvoted ? 'Unlike' : 'Like' %>
                </button>
            </form>
        </div>
    </div>
</div>

<h5>Comments</h5>
<% if (comments && comments.length > 0) { %>
    <% comments.forEach(c => { %>
        <div class="card mb-2">
            <div class="card-body">
                <p><%= c.comment %></p>
                <small>— <strong><%= c.User ? c.User.username : 'Unknown' %></strong> · <%= new Date(c.created_at).toLocaleDateString() %></small>
            </div>
        </div>
    <% }) %>
<% } else { %>
    <p class="text-muted">No comments yet.</p>
<% } %>

<% if (user) { %>
    <form action="/community/tip/<%= tip.id %>/comment" method="POST" class="mt-3">
        <div class="input-group">
            <input type="text" class="form-control" name="comment" placeholder="Add a comment..." required>
            <button class="btn btn-primary" type="submit">Comment</button>
        </div>
    </form>
<% } %>

<%- include('../partials/footer') %>