<%- include('../partials/header', { title: 'Premium Explained' }) %>

<div class="row">
    <div class="col-md-8 mx-auto">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/info">Info Hub</a></li>
                <li class="breadcrumb-item active">Premium</li>
            </ol>
        </nav>

        <div class="card">
            <div class="card-header">
                <h4><i class="fas fa-dollar-sign text-success"></i> Insurance Premium Explained</h4>
            </div>
            <div class="card-body">
                <h5>What is a Premium?</h5>
                <p>
                    <strong>Premium</strong> is the monthly amount you pay for your health insurance coverage.
                    It's calculated based on your risk score and other health factors.
                </p>

                <h5 class="mt-4">How is Premium Calculated?</h5>
                <div class="alert alert-info">
                    <strong>Base Premium:</strong> $50.00 (minimum)
                    <br>
                    <strong>Formula:</strong> Premium = $50 + (Risk Score × $1.50)
                    <br>
                    <small>Example: Risk Score 60 → $50 + (60 × $1.50) = $140/month</small>
                </div>

                <h5 class="mt-4">Premium Examples</h5>
                <table class="table table-bordered">
                    <thead>
                        <tr><th>Risk Score</th><th>Monthly Premium</th><th>Risk Level</th></tr>
                    </thead>
                    <tbody>
                        <tr class="table-success">
                            <td>20</td>
                            <td>$80.00</td>
                            <td>Low</td>
                        </tr>
                        <tr class="table-warning">
                            <td>50</td>
                            <td>$125.00</td>
                            <td>Medium</td>
                        </tr>
                        <tr class="table-danger">
                            <td>80</td>
                            <td>$170.00</td>
                            <td>High</td>
                        </tr>
                    </tbody>
                </table>

                <div class="alert alert-warning">
                    <i class="fas fa-lightbulb"></i>
                    <strong>Tip:</strong> Lower your risk score to reduce your premium:
                    <ul>
                        <li>Maintain a healthy BMI</li>
                        <li>Quit smoking</li>
                        <li>Exercise regularly</li>
                        <li>Improve your health habits</li>
                    </ul>
                </div>

                <a href="/info" class="btn btn-primary mt-3"><i class="fas fa-arrow-left"></i> Back to Info Hub</a>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>