<%- include('../partials/header', { title: 'Manage Claims' }) %>

<h2><i class="fas fa-file-medical"></i> Manage Claims</h2>
<table class="table table-hover">
    <thead>
        <tr><th>ID</th><th>User</th><th>Description</th><th>Status</th><th>Action</th></tr>
    </thead>
    <tbody>
        <% claims.forEach(c => { %>
            <tr>
                <td>#<%= c.id %></td>
                <td><%= c.User ? c.User.username : 'Unknown' %></td>
                <td><%= c.description.substring(0, 50) %>...</td>
                <td><span class="badge <%= c.status === 'Approved' ? 'bg-success' : c.status === 'Rejected' ? 'bg-danger' : 'bg-warning' %>"><%= c.status %></span></td>
                <td>
                    <% if (c.status === 'Pending') { %>
                        <form action="/admin/claim/<%= c.id %>" method="POST" style="display:inline;">
                            <input type="hidden" name="status" value="Approved">
                            <button class="btn btn-success btn-sm">Approve</button>
                        </form>
                        <form action="/admin/claim/<%= c.id %>" method="POST" style="display:inline;">
                            <input type="hidden" name="status" value="Rejected">
                            <button class="btn btn-danger btn-sm">Reject</button>
                        </form>
                    <% } else { %>
                        <span class="text-muted">Done</span>
                    <% } %>
                </td>
            </tr>
        <% }) %>
    </tbody>
</table>

<%- include('../partials/footer') %>