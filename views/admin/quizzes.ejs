<%- include('../partials/header', { title: 'Quiz Results' }) %>

<h2><i class="fas fa-brain text-danger"></i> Quiz Results</h2>
<p class="text-muted">View all users' health quiz scores</p>

<div class="card">
    <div class="card-body">
        <% if (quizzes && quizzes.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>User</th>
                            <th>Email</th>
                            <th>Health Score</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% quizzes.forEach(q => { %>
                            <tr>
                                <td>#<%= q.id %></td>
                                <td><%= q.User ? q.User.username : 'Unknown' %></td>
                                <td><%= q.User ? q.User.email : 'N/A' %></td>
                                <td>
                                    <span class="badge <%= q.health_score >= 80 ? 'bg-success' : 
                                        q.health_score >= 60 ? 'bg-warning' : 'bg-danger' %>">
                                        <%= q.health_score %>%
                                    </span>
                                </td>
                                <td><%= q.completed_at ? new Date(q.completed_at).toLocaleDateString() : 'N/A' %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <p class="text-muted text-center">No quiz results yet.</p>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>