<%- include('../partials/header', { title: 'Admin Dashboard' }) %>

<h2><i class="fas fa-crown text-warning"></i> Admin Dashboard</h2>
<p class="text-muted">Overview of InsurePro platform</p>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h6>Total Users</h6>
                <h2><%= totalUsers %></h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h6>Total Claims</h6>
                <h2><%= totalClaims %></h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h6>Pending Claims</h6>
                <h2><%= pendingClaims %></h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-danger">
            <div class="card-body">
                <h6>Avg Risk Score</h6>
                <h2><%= avgRisk.toFixed(1) %></h2>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Recent Users</div>
            <div class="card-body">
                <ul class="list-group">
                    <% recentUsers.forEach(u => { %>
                        <li class="list-group-item"><%= u.username %> (<%= u.email %>)</li>
                    <% }) %>
                </ul>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Recent Claims</div>
            <div class="card-body">
                <ul class="list-group">
                    <% recentClaims.forEach(c => { %>
                        <li class="list-group-item">#<%= c.id %> - <%= c.status %> (<%= c.createdAt.toLocaleDateString() %>)</li>
                    <% }) %>
                </ul>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>