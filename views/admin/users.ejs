<%- include('../partials/header', { title: 'Manage Users' }) %>

<h2><i class="fas fa-users"></i> Manage Users</h2>
<table class="table table-hover">
    <thead>
        <tr><th>ID</th><th>Username</th><th>Email</th><th>Age</th><th>BMI</th><th>Actions</th></tr>
    </thead>
    <tbody>
        <% users.forEach(u => { %>
            <tr>
                <td><%= u.id %></td>
                <td><%= u.username %></td>
                <td><%= u.email %></td>
                <td><%= u.age || 'N/A' %></td>
                <td><%= u.bmi || 'N/A' %></td>
                <td>
                    <form action="/admin/user/<%= u.id %>?_method=DELETE" method="POST" style="display:inline;">
                        <button class="btn btn-danger btn-sm delete-confirm"><i class="fas fa-trash"></i></button>
                    </form>
                </td>
            </tr>
        <% }) %>
    </tbody>
</table>

<%- include('../partials/footer') %>