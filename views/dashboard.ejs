<%- include('partials/header', { title: 'Dashboard - InsurePro' }) %>

<div class="row mb-4">
    <div class="col-12">
        <h2><i class="fas fa-chart-line text-primary"></i> Dashboard</h2>
        <p class="text-muted">Welcome back, <%= user.username %>!</p>
    </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h6 class="card-title">Risk Score</h6>
                <h2 class="mb-0"><%= riskProfile ? riskProfile.risk_score : 'N/A' %></h2>
                <small>/ 100</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h6 class="card-title">Monthly Premium</h6>
                <h2 class="mb-0">$<%= riskProfile ? riskProfile.premium : '50.00' %></h2>
                <small>Estimated</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h6 class="card-title">Total Claims</h6>
                <h2 class="mb-0"><%= claimsCount %></h2>
                <small>Filed</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-danger">
            <div class="card-body">
                <h6 class="card-title">Pending Claims</h6>
                <h2 class="mb-0"><%= pendingClaims %></h2>
                <small>Awaiting review</small>
            </div>
        </div>
    </div>
</div>

<!-- Chart -->
<div class="row mb-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h6><i class="fas fa-chart-area"></i> Risk Score History</h6>
            </div>
            <div class="card-body">
                <canvas id="riskChart" height="200"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6><i class="fas fa-user"></i> Your Profile</h6>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Username</span>
                        <strong><%= user.username %></strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Email</span>
                        <strong><%= user.email %></strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Age</span>
                        <strong><%= user.age || 'Not set' %></strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>BMI</span>
                        <strong><%= user.bmi || 'Not set' %></strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Smoking</span>
                        <strong><%= user.smoking ? 'Yes' : 'No' %></strong>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Recent Claims -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6><i class="fas fa-file-medical"></i> Recent Claims</h6>
                <a href="/claim/file" class="btn btn-primary btn-sm">
                    <i class="fas fa-plus"></i> New Claim
                </a>
            </div>
            <div class="card-body">
                <% if (claims && claims.length > 0) { %>
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Description</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% claims.forEach(claim => { %>
                                <tr>
                                    <td>#<%= claim.id %></td>
                                    <td><%= claim.description.substring(0, 50) %>...</td>
                                    <td>
                                        <span class="badge <%= claim.status === 'Approved' ? 'bg-success' : 
                                            claim.status === 'Rejected' ? 'bg-danger' : 'bg-warning' %>">
                                            <%= claim.status %>
                                        </span>
                                    </td>
                                    <td><%= claim.createdAt ? new Date(claim.createdAt).toLocaleDateString() : 'N/A' %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } else { %>
                    <p class="text-muted text-center">No claims filed yet.</p>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const ctx = document.getElementById('riskChart').getContext('2d');
    const chartData = JSON.parse('<%- JSON.stringify(chartData) %>' || '[]');
    
    if (chartData.length > 0) {
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: chartData.map(d => d.date),
                datasets: [{
                    label: 'Risk Score',
                    data: chartData.map(d => d.score),
                    borderColor: '#3498db',
                    backgroundColor: 'rgba(52, 152, 219, 0.1)',
                    tension: 0.4,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top'
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 100
                    }
                }
            }
        });
    } else {
        document.querySelector('.card canvas').parentElement.innerHTML = 
            '<p class="text-muted text-center">No data available yet. Calculate your first risk score!</p>';
    }
});
</script>

<%- include('partials/footer') %>