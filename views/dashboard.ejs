<%- include('partials/header', { title: 'Dashboard - InsurePro' }) %>

<!-- ===== WELCOME ===== -->
<div class="row mb-4">
    <div class="col-12">
        <h2><i class="fas fa-chart-line text-danger"></i> Dashboard</h2>
        <p class="text-muted">Welcome back, <strong><%= user.username %></strong>!</p>
    </div>
</div>

<!-- ===== STATS CARDS ===== -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-danger">
            <div class="card-body">
                <h6 class="card-title">Risk Score</h6>
                <h2 class="mb-0"><%= riskProfile ? riskProfile.risk_score : 'N/A' %></h2>
                <small>/ 100</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h6 class="card-title">Monthly Premium</h6>
                <h2 class="mb-0">$<%= riskProfile ? riskProfile.premium : '50.00' %></h2>
                <small>Estimated</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h6 class="card-title">Total Claims</h6>
                <h2 class="mb-0"><%= claimsCount || 0 %></h2>
                <small>Filed</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-danger">
            <div class="card-body">
                <h6 class="card-title">Pending Claims</h6>
                <h2 class="mb-0"><%= pendingClaims || 0 %></h2>
                <small>Awaiting review</small>
            </div>
        </div>
    </div>
</div>

<!-- ===== CHART + PROFILE ===== -->
<div class="row mb-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h6><i class="fas fa-chart-area text-danger"></i> Risk Score History</h6>
            </div>
            <div class="card-body">
                <canvas id="riskChart" height="200"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6><i class="fas fa-user text-danger"></i> Your Profile</h6>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Username</span>
                        <strong><%= user.username %></strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Email</span>
                        <strong><%= user.email %></strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Age</span>
                        <strong><%= user.age || 'Not set' %></strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>BMI</span>
                        <strong><%= user.bmi || 'Not set' %></strong>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span>Smoking</span>
                        <strong><%= user.smoking ? 'Yes' : 'No' %></strong>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- ===== RECENT CLAIMS ===== -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6><i class="fas fa-file-medical text-danger"></i> Recent Claims</h6>
                <a href="/claim/file" class="btn btn-danger btn-sm">
                    <i class="fas fa-plus"></i> New Claim
                </a>
            </div>
            <div class="card-body">
                <% if (claims && claims.length > 0) { %>
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Description</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% claims.forEach(claim => { %>
                                <tr>
                                    <td>#<%= claim.id %></td>
                                    <td><%= claim.description ? claim.description.substring(0, 50) + '...' : 'No description' %></td>
                                    <td>
                                        <span class="badge <%= claim.status === 'Approved' ? 'bg-success' : 
                                            claim.status === 'Rejected' ? 'bg-danger' : 'bg-warning' %>">
                                            <%= claim.status || 'Pending' %>
                                        </span>
                                    </td>
                                    <td>
                                        <%= claim.createdAt ? new Date(claim.createdAt).toLocaleDateString() : 
                                            claim.created_at ? new Date(claim.created_at).toLocaleDateString() : 
                                            'N/A' %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } else { %>
                    <p class="text-muted text-center">No claims filed yet.</p>
                <% } %>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const ctx = document.getElementById('riskChart');
    if (ctx) {
        const chartData = JSON.parse('<%- JSON.stringify(chartData) %>' || '[]');
        if (chartData.length > 0) {
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: chartData.map(d => d.date || 'N/A'),
                    datasets: [{
                        label: 'Risk Score',
                        data: chartData.map(d => d.score || 0),
                        borderColor: '#dc3545',
                        backgroundColor: 'rgba(220, 53, 69, 0.1)',
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: true, position: 'top' } },
                    scales: { y: { beginAtZero: true, max: 100 } }
                }
            });
        } else {
            document.querySelector('.card canvas')?.parentElement?.replaceWith(
                '<p class="text-muted text-center">No data available yet. Calculate your first risk score!</p>'
            );
        }
    }
});
</script>