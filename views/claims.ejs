<%- include('partials/header', { title: 'My Claims - InsurePro' }) %>

<div class="row mb-4">
    <div class="col-12">
        <h2><i class="fas fa-file-medical text-primary"></i> My Claims</h2>
        <p class="text-muted">View all your filed claims</p>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <% if (claims && claims.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Claim ID</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Document</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% claims.forEach(claim => { %>
                            <tr>
                                <td><strong>#<%= claim.id %></strong></td>
                                <td><%= claim.description %></td>
                                <td>
                                    <span class="badge <%= claim.status === 'Approved' ? 'bg-success' : 
                                        claim.status === 'Rejected' ? 'bg-danger' : 'bg-warning' %>">
                                        <%= claim.status %>
                                    </span>
                                </td>
                                <td>
                                    <% if (claim.document_path) { %>
                                        <a href="/<%= claim.document_path %>" target="_blank" class="btn btn-sm btn-info">
                                            <i class="fas fa-file-alt"></i> View
                                        </a>
                                    <% } else { %>
                                        <span class="text-muted">No file</span>
                                    <% } %>
                                </td>
                                <td><%= claim.createdAt.toLocaleDateString() %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="text-center py-5">
                <i class="fas fa-file-medical fa-4x text-muted mb-3"></i>
                <h5>No Claims Found</h5>
                <p class="text-muted">You haven't filed any claims yet.</p>
                <a href="/claim/file" class="btn btn-primary">
                    <i class="fas fa-plus"></i> File Your First Claim
                </a>
            </div>
        <% } %>
    </div>
</div>

<%- include('partials/footer') %>