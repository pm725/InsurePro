<%- include('partials/header', { title: 'Calculate Risk - InsurePro' }) %>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-lg border-0">
            <div class="card-body p-5">
                <h3 class="text-center mb-4">
                    <i class="fas fa-calculator text-primary"></i> Risk Assessment
                </h3>
                <p class="text-center text-muted">Calculate your health risk score and premium estimate</p>

                <% if (error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>

                <% if (result) { %>
                    <!-- Result Display -->
                    <div class="alert alert-success">
                        <h5 class="text-center">Your Results</h5>
                        <hr>
                        <div class="row text-center">
                            <div class="col-4">
                                <h6>Risk Score</h6>
                                <h2 class="<%= result.riskScore > 70 ? 'text-danger' : 
                                    result.riskScore > 40 ? 'text-warning' : 'text-success' %>">
                                    <%= result.riskScore %>
                                </h2>
                                <small>Level: <%= result.riskLevel %></small>
                            </div>
                            <div class="col-4">
                                <h6>Premium</h6>
                                <h2 class="text-primary">$<%= result.premium %></h2>
                                <small>Monthly</small>
                            </div>
                            <div class="col-4">
                                <h6>Status</h6>
                                <h6>
                                    <span class="badge <%= result.riskLevel === 'Low' ? 'bg-success' : 
                                        result.riskLevel === 'Medium' ? 'bg-warning' : 'bg-danger' %>">
                                        <%= result.riskLevel %>
                                    </span>
                                </h6>
                                <small>Risk Level</small>
                            </div>
                        </div>
                        <hr>
                        <div class="text-center">
                            <a href="/dashboard" class="btn btn-primary">
                                <i class="fas fa-chart-line"></i> View Dashboard
                            </a>
                            <a href="/risk/calculate" class="btn btn-outline-primary">
                                <i class="fas fa-redo"></i> Recalculate
                            </a>
                        </div>
                    </div>
                <% } else { %>
                    <!-- Risk Form -->
                    <form action="/risk/calculate" method="POST">
                        <div class="mb-3">
                            <label for="age" class="form-label">Age</label>
                            <input type="number" class="form-control" id="age" 
                                   name="age" placeholder="Enter your age" 
                                   min="18" max="100" required 
                                   value="<%= user.age || '' %>">
                            <small class="text-muted">Between 18-100 years</small>
                        </div>

                        <div class="mb-3">
                            <label for="bmi" class="form-label">BMI (Body Mass Index)</label>
                            <input type="number" class="form-control" id="bmi" 
                                   name="bmi" placeholder="Enter your BMI" 
                                   step="0.1" min="10" max="50" required
                                   value="<%= user.bmi || '' %>">
                            <small class="text-muted">Between 10-50</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Smoking Status</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="smoking" 
                                       id="smokingNo" value="false" 
                                       <%= !user.smoking ? 'checked' : '' %>>
                                <label class="form-check-label" for="smokingNo">
                                    Non-smoker
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="smoking" 
                                       id="smokingYes" value="true"
                                       <%= user.smoking ? 'checked' : '' %>>
                                <label class="form-check-label" for="smokingYes">
                                    Smoker
                                </label>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-calculator"></i> Calculate Risk
                        </button>
                    </form>
                <% } %>

                <hr class="my-4">
                <div class="text-center">
                    <small class="text-muted">
                        Your data is secure and only used for risk assessment purposes.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>